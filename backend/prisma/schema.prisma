generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id        Int      @id @default(autoincrement())
  username  String   @unique @db.VarChar(50)
  password  String   @db.VarChar(255)
  photo_url String?  @db.VarChar(255)
  secret    String   @db.VarChar(255)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  role      Role
  isActive  Boolean  @default(true)
}

model Teacher {
  id         Int      @id @default(autoincrement())
  firstName  String   @db.VarChar(255)
  secondName String   @db.VarChar(255)
  photo_url  String?  @db.VarChar(255)
  createdAt  DateTime @default(now())
  phone      String?
  updatedAt  DateTime @updatedAt
  role       Role     @default(TEACHER)
  Blog       Blog[]
  Course     Course[]
  Groups     Group[]
}

model Course {
  id              Int          @id @default(autoincrement())
  name            String       @unique @db.VarChar(255)
  nameCertificate String       @db.VarChar(255)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  teacherId       Int
  teacher         Teacher      @relation(fields: [teacherId], references: [id])
  Group           Group[]
  NewStudent      NewStudent[]
  Student         Student[]
}

model Group {
  id              Int        @id @default(autoincrement())
  name            String     @unique @db.VarChar(60)
  isGroupFinished Boolean    @default(false)
  createdAt       DateTime   @default(now())
  finishedDate    DateTime?
  price           Decimal    @db.Decimal
  duration        Int
  groupTime       String?    @db.VarChar(20)
  courseId        Int
  teacherId       Int
  course          Course     @relation(fields: [courseId], references: [id])
  teacher         Teacher    @relation(fields: [teacherId], references: [id])
  schedules       Schedule[]
  Students        Student[]
}

model Room {
  id        Int        @id @default(autoincrement())
  name      String     @unique
  capacity  Int?
  schedules Schedule[]
}

model Schedule {
  id          Int          @id @default(autoincrement())
  weekType    WeekType
  time        LessonTime
  roomId      Int
  groupId     Int
  attendances Attendance[]
  group       Group        @relation(fields: [groupId], references: [id])
  Room        Room         @relation(fields: [roomId], references: [id])

  @@unique([roomId, weekType, time])
}

model Attendance {
  id         Int       @id @default(autoincrement())
  studentId  Int
  date       DateTime
  subject    String
  present    Boolean
  createdAt  DateTime  @default(now())
  scheduleId Int?
  Schedule   Schedule? @relation(fields: [scheduleId], references: [id])
  Student    Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model Student {
  id           Int          @id @default(autoincrement())
  firstName    String       @db.VarChar(50)
  secondName   String       @db.VarChar(50)
  passportId   String?      @unique @db.VarChar(10)
  paymentType  PaymentType  @default(selfPayment)
  gender       gender
  debt         Decimal      @default(0.00)
  code         String       @unique
  discount     Decimal      @default(0.00)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  phone        String?      @db.VarChar(50)
  finishedDate DateTime?
  courseId     Int
  groupId      Int
  attendances  Attendance[]
  Payments     Payment[]
  course       Course       @relation(fields: [courseId], references: [id])
  Group        Group        @relation(fields: [groupId], references: [id], onDelete: Cascade)
}

model Payment {
  id          Int       @id @default(autoincrement())
  paymentDate DateTime  @default(now())
  amount      Decimal
  status      String    @default("Paid")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  studentId   Int
  isRefunded  Boolean   @default(false)
  refundedAt  DateTime?
  Student     Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  refunds     Refund[]
}

model Refund {
  id        Int      @id @default(autoincrement())
  paymentId Int
  amount    Decimal
  createdAt DateTime @default(now())
  reason    String?
  payment   Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)
}

model Messages {
  id        Int      @id @default(autoincrement())
  fullName  String   @db.VarChar(255)
  message   String
  createdAt DateTime @default(now())
}

model NewStudent {
  id         Int      @id @default(autoincrement())
  fullName   String
  phone      String
  courseTime String
  createdAt  DateTime @default(now())
  isAttend   isAttend @default(PENDING)
  reason     String?
  courseId   Int
  course     Course   @relation(fields: [courseId], references: [id])
}

model News {
  id          Int      @id @default(autoincrement())
  slug        String   @unique
  photo_url   String?
  title       String
  description String
  content     String
  createdAt   DateTime @default(now())
}

model Blog {
  id         Int       @id @default(autoincrement())
  title      String
  slug       String    @unique
  content    String
  authorId   Int
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  views      Int       @default(0)
  categoryId Int?
  author     Teacher   @relation(fields: [authorId], references: [id])
  Category   Category? @relation(fields: [categoryId], references: [id])
}

model Category {
  id    Int    @id @default(autoincrement())
  name  String @unique
  blogs Blog[]
}

enum Role {
  ADMIN
  TEACHER
  RECEPTION
}

enum gender {
  MALE
  FEMALE
}

enum PaymentType {
  contract
  selfPayment
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
}

enum isAttend {
  PENDING
  CAME
  NOT_CAME
}

enum WeekType {
  ODD
  EVEN
}

enum LessonTime {
  T09_00
  T11_00
  T14_00
  T16_00
}

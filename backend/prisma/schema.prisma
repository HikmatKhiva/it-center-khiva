// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  TEACHER
  RECEPTION
}

enum gender {
  MALE
  FEMALE
}

enum PaymentType {
  contract
  selfPayment
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  // SUNDAY
}

enum isAttend {
  PENDING
  CAME
  NOT_CAME
}

model Admin {
  id        Int      @id @default(autoincrement()) // Ensure PostgreSQL is configured correctly
  username  String   @unique @db.VarChar(50)
  password  String   @db.VarChar(255)
  photo_url String?  @db.VarChar(255)
  secret    String   @db.VarChar(255)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt // Ensure database triggers are enabled for automatic updates
  role      Role
  isActive  Boolean  @default(true)
}

model Teacher {
  id         Int       @id @default(autoincrement())
  firstName  String    @db.VarChar(255)
  secondName String    @db.VarChar(255)
  // username   String?    @unique @db.VarChar(50) // Kirish uchun
  // password   String    @db.VarChar(255)
  photo_url  String?   @db.VarChar(255)
  createdAt  DateTime  @default(now())
  // lastLogin  DateTime?
  phone      String?
  // isActive   Boolean   @default(true)
  updatedAt  DateTime  @updatedAt
  Groups     Group[]
  Blog       Blog[]
  Course     Course[]
  role       Role      @default(TEACHER)
}

model Course {
  id              Int          @id @default(autoincrement())
  name            String       @unique @db.VarChar(255)
  nameCertificate String       @db.VarChar(255)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  teacher         Teacher      @relation(fields: [teacherId], references: [id])
  Student         Student[]
  Group           Group[]
  // Foreign key relationship to the Teachers table
  NewStudent      NewStudent[]
  teacherId       Int
}

model Group {
  id              Int        @id @default(autoincrement())
  name            String     @unique @db.VarChar(60)
  isGroupFinished Boolean    @default(false)
  createdAt       DateTime   @default(now())
  finishedDate    DateTime?
  price           Decimal    @db.Decimal
  duration        Int
  groupTime       String?    @db.VarChar(20)
  // Foreign key relationships
  teacher         Teacher    @relation(fields: [teacherId], references: [id])
  course          Course     @relation(fields: [courseId], references: [id])
  schedules       Schedule[]

  Students  Student[]
  courseId  Int // course_id (nullable)
  teacherId Int // teacher_id (nullable)
}

model Room {
  id        Int        @id @default(autoincrement())
  name      String     @unique
  capacity  Int?
  schedules Schedule[]
}

enum WeekType {
  ODD
  EVEN
}

enum LessonTime {
  T09_00
  T11_00
  T14_00
  T16_00
}

model Schedule {
  id       Int        @id @default(autoincrement())
  weekType WeekType
  time     LessonTime
  Room     Room       @relation(fields: [roomId], references: [id])
  group    Group      @relation(fields: [groupId], references: [id])
  roomId   Int
  groupId  Int

  attendances Attendance[]

  @@unique([roomId, weekType, time])
}

model Attendance {
  id         Int       @id @default(autoincrement())
  studentId  Int
  date       DateTime // dars sanasi (startTime ni ham ishlatish mumkin)
  subject    String // Dars mavzusi
  present    Boolean
  Student    Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  createdAt  DateTime  @default(now())
  scheduleId Int?
  Schedule   Schedule? @relation(fields: [scheduleId], references: [id])
}

model Student {
  id           Int         @id @default(autoincrement())
  firstName    String      @db.VarChar(50)
  secondName   String      @db.VarChar(50)
  passportId   String?     @unique @db.VarChar(9)
  paymentType  PaymentType
  gender       gender
  debt         Decimal     @default(0.00)
  code         String      @unique
  Group        Group       @relation(fields: [groupId], references: [id], onDelete: Cascade)
  course       Course      @relation(fields: [courseId], references: [id])
  discount     Decimal     @default(0.00)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  phone        String?     @db.VarChar(50)
  finishedDate DateTime?
  // Foreign key relationships
  Payments     Payment[]
  courseId     Int
  groupId      Int

  attendances Attendance[]
}

model Payment {
  id          Int       @id @default(autoincrement())
  paymentDate DateTime  @default(now())
  amount      Decimal
  status      String    @default("Paid")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  // Foreign key relationships
  Student     Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId   Int
  isRefunded  Boolean   @default(false)
  refundedAt  DateTime?

  refunds Refund[]
}

model Refund {
  id        Int      @id @default(autoincrement())
  paymentId Int
  amount    Decimal
  createdAt DateTime @default(now())
  reason    String?
  payment   Payment  @relation(fields: [paymentId], references: [id])
}

model Messages {
  id        Int      @id @default(autoincrement())
  fullName  String   @db.VarChar(255)
  message   String   @db.Text
  createdAt DateTime @default(now())
}

model NewStudent {
  id         Int      @id @default(autoincrement())
  fullName   String
  phone      String
  courseTime String
  createdAt  DateTime @default(now())

  isAttend isAttend @default(PENDING)
  reason   String?
  // Foreign key relationship to Course
  course   Course  @relation(fields: [courseId], references: [id])
  courseId Int
}

model News {
  id          Int      @id @default(autoincrement())
  slug        String   @unique // Add slug field
  photo_url   String?  @db.Text
  title       String   @db.Text
  description String   @db.Text
  content     String   @db.Text
  createdAt   DateTime @default(now())
}

model Blog {
  id        Int      @id @default(autoincrement())
  title     String   @db.Text
  slug      String   @unique // Add slug field
  content   String   @db.Text
  authorId  Int // Foreign key to Teacher model
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  views     Int      @default(0) // Track the number of views

  author     Teacher   @relation(fields: [authorId], references: [id])
  Category   Category? @relation(fields: [categoryId], references: [id])
  categoryId Int?
}

model Category {
  id    Int    @id @default(autoincrement())
  name  String @unique
  blogs Blog[] // Many-to-many relationship with Blog
}

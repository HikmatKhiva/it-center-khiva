generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id        Int       @id @default(autoincrement())
  username  String    @unique @db.VarChar(50)
  password  String    @db.VarChar(255)
  photo_url String?   @db.VarChar(255)
  secret    String    @db.VarChar(255)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  role      Role
  isActive  Boolean   @default(true)
  // Add online status
  isOnline  Boolean   @default(false)
  lastSeen  DateTime?
  payments  Payment[]
  refunds   Refund[]
}

model Teacher {
  id         Int      @id @default(autoincrement())
  firstName  String   @db.VarChar(255)
  secondName String   @db.VarChar(255)
  photo_url  String?  @db.VarChar(255)
  createdAt  DateTime @default(now())
  phone      String?
  updatedAt  DateTime @updatedAt
  role       Role     @default(TEACHER)
  commissionRate Float  @default(0.5)  // Custom per teacher!
  Blog   Blog[]
  Course Course[]
  Groups Group[]
}

model Course {
  id              Int          @id @default(autoincrement())
  name            String       @unique @db.VarChar(255)
  nameCertificate String       @db.VarChar(255)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  teacherId       Int
  teacher         Teacher      @relation(fields: [teacherId], references: [id])
  Group           Group[]
  NewStudent      NewStudent[]
  Student         Student[]
}

model Group {
  id           Int        @id @default(autoincrement())
  name         String     @unique @db.VarChar(60)
  createdAt    DateTime   @default(now())
  finishedDate DateTime?
  price        Decimal    @db.Decimal
  duration     Int
  courseId     Int
  teacherId    Int
  course       Course     @relation(fields: [courseId], references: [id])
  teacher      Teacher    @relation(fields: [teacherId], references: [id])
  startTime    DateTime?
  isActive     IsActive   @default(PENDING)
  schedules    Schedule[]
  Students     Student[]
}

model Room {
  id        Int        @id @default(autoincrement())
  name      String     @unique
  capacity  Int?
  schedules Schedule[]
}

model Schedule {
  id          Int          @id @default(autoincrement())
  weekType    WeekType
  time        LessonTime
  roomId      Int
  groupId     Int
  attendances Attendance[]
  group       Group        @relation(fields: [groupId], references: [id])
  Room        Room         @relation(fields: [roomId], references: [id])

  @@unique([roomId, weekType, time])
}

model Attendance {
  id         Int       @id @default(autoincrement())
  studentId  Int
  date       DateTime
  subject    String
  present    Boolean
  createdAt  DateTime  @default(now())
  scheduleId Int?
  Schedule   Schedule? @relation(fields: [scheduleId], references: [id])
  Student    Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model Student {
  id           Int          @id @default(autoincrement())
  firstName    String       @db.VarChar(50)
  secondName   String       @db.VarChar(50)
  passportId   String?      @unique @db.VarChar(10)
  issueAt      DateTime?
  paymentType  PaymentType  @default(selfPayment)
  address      String       @db.VarChar(255)
  gender       gender
  debt         Decimal      @default(0.00)
  debtStatus   DebtStatus   @default(PENDING)
  code         String       @unique
  discount     Decimal      @default(0.00)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  phone        String?      @db.VarChar(50)
  finishedDate DateTime?
  courseId     Int
  groupId      Int
  attendances  Attendance[]
  Payments     Payment[]
  docType      DocType
  receipts     Receipt[]
  course       Course       @relation(fields: [courseId], references: [id])
  Group        Group        @relation(fields: [groupId], references: [id], onDelete: Cascade)
  guarantorId  Int?
  guarantor    Guarantor?   @relation(fields: [guarantorId], references: [id], onDelete: Cascade)

  @@index([groupId, courseId])
}

model Guarantor {
  id         Int       @id @default(autoincrement())
  firstName  String    @db.VarChar(50)
  secondName String    @db.VarChar(50)
  passportId String    @unique @db.VarChar(10)
  issueAt    DateTime
  phone      String    @db.VarChar(50)
  students   Student[]
}

model Payment {
  id              Int             @id @default(autoincrement())
  paymentDate     DateTime        @default(now())
  amount          Decimal
  status          String          @default("Paid")
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  studentId       Int
  isRefunded      Boolean         @default(false)
  refundedAt      DateTime?
  createdById     Int
  createdBy       Admin           @relation(fields: [createdById], references: [id])
  Student         Student         @relation(fields: [studentId], references: [id], onDelete: Cascade)
  confirmedAt     DateTime?
  confirmedStatus ConfirmedStatus @default(PENDING)
  receipts        Receipt?
  refunds         Refund[]

  @@index([studentId])
}

model Receipt {
  id          Int           @id @default(autoincrement())
  receiptNo   String        @unique
  publicToken String        @unique
  paymentId   Int           @unique
  studentId   Int
  amount      Decimal
  status      ReceiptStatus @default(ACTIVE)
  issuedAt    DateTime      @default(now())
  payment     Payment       @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  student     Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  cancelledAt DateTime?

  @@index([studentId])
}

model Refund {
  id            Int      @id @default(autoincrement())
  amount        Decimal
  createdAt     DateTime @default(now())
  reason        String
  payment       Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  paymentId     Int
  cancelledBy   Admin    @relation(fields: [cancelledById], references: [id])
  cancelledById Int

  @@index([paymentId])
}

model Messages {
  id        Int      @id @default(autoincrement())
  fullName  String   @db.VarChar(255)
  message   String
  createdAt DateTime @default(now())
}

model NewStudent {
  id         Int      @id @default(autoincrement())
  fullName   String
  phone      String
  courseTime String
  createdAt  DateTime @default(now())
  isAttend   isAttend @default(PENDING)
  reason     String?
  courseId   Int
  course     Course   @relation(fields: [courseId], references: [id])
}

model News {
  id          Int      @id @default(autoincrement())
  slug        String   @unique
  photo_url   String?
  title       String
  description String
  content     String
  createdAt   DateTime @default(now())
}

model Blog {
  id         Int       @id @default(autoincrement())
  title      String
  slug       String    @unique
  content    String
  authorId   Int
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  views      Int       @default(0)
  categoryId Int?
  author     Teacher   @relation(fields: [authorId], references: [id])
  Category   Category? @relation(fields: [categoryId], references: [id])
}

model Category {
  id    Int    @id @default(autoincrement())
  name  String @unique
  blogs Blog[]
}

model TestQuestion {
  id        Int          @id @default(autoincrement())
  question  String
  createdAt DateTime     @default(now())
  answers   TestAnswer[]
}

model TestAnswer {
  id         Int          @id @default(autoincrement())
  text       String
  questionId Int
  question   TestQuestion @relation(fields: [questionId], references: [id])

  frontend Int @default(0)
  smm      Int @default(0)
  backend  Int @default(0)
  computer Int @default(0)
}

model TestResult {
  id          Int      @id @default(autoincrement())
  fullName    String
  phone       String
  frontend    Int
  backend     Int
  smm         Int
  computer    Int
  recommended String
  createdAt   DateTime @default(now())
}

enum Role {
  ADMIN
  TEACHER
  RECEPTION
}

enum ReceiptStatus {
  ACTIVE
  CANCELLED
}

enum gender {
  MALE
  FEMALE
}

enum PaymentType {
  contract
  selfPayment
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
}

enum isAttend {
  PENDING
  CAME
  NOT_CAME
}

enum WeekType {
  ODD
  EVEN
}

enum LessonTime {
  T09_00
  T11_00
  T14_00
  T16_00
}

enum DocType {
  PASSPORT
  BIRTHCERTIFICATE
}

enum DebtStatus {
  PENDING
  ACTIVE
  PAID
}

enum IsActive {
  FINISHED
  ACTIVE
  PENDING
}

enum ConfirmedStatus {
  PENDING
  CONFIRMED
}
